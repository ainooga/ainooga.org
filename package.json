{
  "name": "ainooga.org",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:all": "pnpm run build:content && (pnpm run worker:dev & sleep 2 && pnpm run dev)",
    "build": "npm run build:content && npm run build:spa",
    "build:content": "tsx scripts/build.ts",
    "build:spa": "vite build",
    "preview": "vite preview",
    "lint": "eslint --max-warnings 0 src/ scripts/",
    "format": "prettier --check src/ scripts/ content/",
    "format:write": "prettier --write src/ scripts/ content/",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "complexity": "npm run complexity:eslint",
    "complexity:eslint": "eslint src/ scripts/ --max-warnings 0",
    "complexity:escomplex": "echo 'complexity:escomplex: no maintainability-index CLI available; all other gates enforced by complexity:eslint'",
    "check": "npm run lint && npm run type-check && npm run test && npm run complexity",
    "setup": "tsx scripts/setup.ts",
    "cf:login": "wrangler login",
    "worker:dev": "cd worker && wrangler dev",
    "worker:deploy": "cd worker && wrangler deploy",
    "cf:dev": "cd worker && wrangler dev",
    "cf:dev:pages-old": "wrangler pages dev dist/",
    "cf:migrate": "wrangler d1 migrations apply ainooga-d1 --remote",
    "cf:migrate:local": "wrangler d1 migrations apply ainooga-d1 --local",
    "cf:deploy": "wrangler pages deploy dist/ --project-name=ainooga-org",
    "cf:backup": "wrangler d1 export ainooga-d1 --output=./backups/$(date +%F).sql",
    "precommit": "lint-staged",
    "prepush": "npm run check"
  },
  "simple-git-hooks": {
    "pre-commit": ".githooks/pre-commit",
    "pre-push": ".githooks/pre-push"
  },
  "lint-staged": {
    "{src,scripts,worker,tests}/**/*.{ts,svelte}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{md,json,yaml,yml}": [
      "prettier --write"
    ],
    "*.{jpg,jpeg,png,gif}": [
      "scripts/check-image-size.sh"
    ]
  },
  "dependencies": {
    "marked": "^15.0.0",
    "svelte": "^5.56.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.52.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.0",
    "@testing-library/svelte": "^5.2.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.30.0",
    "@typescript-eslint/parser": "^8.30.0",
    "eslint": "^9.25.0",
    "eslint-plugin-sonarjs": "^3.0.0",
    "eslint-plugin-svelte": "^3.5.0",
    "globals": "^17.6.0",
    "gray-matter": "^4.0.3",
    "jsdom": "^26.0.0",
    "lint-staged": "^15.5.0",
    "prettier": "^3.5.0",
    "prettier-plugin-svelte": "^3.3.0",
    "sharp": "^0.34.0",
    "simple-git-hooks": "^2.12.0",
    "svelte-eslint-parser": "^1.8.0",
    "svelte-spa-router": "^4.0.1",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.61.0",
    "vite": "^6.3.0",
    "vitest": "^3.1.0",
    "wrangler": "^4.102.0",
    "zod": "^3.24.0",
    "zod-validation-error": "^3.4.0"
  }
}
